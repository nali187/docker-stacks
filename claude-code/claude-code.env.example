# NICHT die echte .env committen - nur diese .example-Datei gehoert ins Repo.
# In Portainer als Stack-Umgebungsvariablen setzen.

# Erzeugen via "claude setup-token" auf einem BEREITS eingeloggten Rechner
# (z.B. deinem Heim-PC) - der Container selbst hat keinen Browser fuer den
# normalen OAuth-Login-Flow.
CLAUDE_CODE_OAUTH_TOKEN=

# InfluxDB3: docker exec influxdb3-core influxdb3 create token --admin --name claude-mcp-token --token <ADMIN_TOKEN>
INFLUXDB_MCP_TOKEN=
